# NexusFleet Configuration

# API Base (if needed in future)
VITE_API_BASE_URL=http://localhost:3000/api

# Feature Flags
VITE_ENABLE_CHAT_SUPPORT=true
VITE_ENABLE_PAYMENTS=true
VITE_ENABLE_KYC=true

# Pricing
VITE_BASE_PRICE=72
VITE_WEIGHT_MULTIPLIER=22
VITE_DISTANCE_MULTIPLIER=4.4
VITE_EXPRESS_MULTIPLIER=1.45
VITE_MIN_BOOKING_PRICE=180

# Validation
VITE_MIN_PASSWORD_LENGTH=6
VITE_MAX_DISTANCE_KM=500
VITE_MAX_WEIGHT_KG=100

# UI
VITE_ITEMS_PER_PAGE=10
VITE_APP_NAME=NexusFleet
